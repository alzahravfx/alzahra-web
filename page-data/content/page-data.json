{"componentChunkName":"component---src-pages-content-js","path":"/content/","result":{"data":{"allContentfulEntry":{"nodes":[{"id":"2ee266b3-ba18-52a2-906e-5cceb3e62dfd","title":"Trophy","content":{"raw":"{\"nodeType\":\"document\",\"data\":{},\"content\":[{\"nodeType\":\"paragraph\",\"data\":{},\"content\":[{\"nodeType\":\"text\",\"value\":\"Director : Javad Matouri\",\"marks\":[],\"data\":{}}]},{\"nodeType\":\"paragraph\",\"data\":{},\"content\":[{\"nodeType\":\"text\",\"value\":\"Production Studio : Alzahra Animation and VFX Studio\",\"marks\":[],\"data\":{}}]},{\"nodeType\":\"paragraph\",\"data\":{},\"content\":[{\"nodeType\":\"text\",\"value\":\"Duration : 90 Minutes\",\"marks\":[],\"data\":{}}]},{\"nodeType\":\"paragraph\",\"data\":{},\"content\":[{\"nodeType\":\"text\",\"value\":\"Technique : 3D Animation\",\"marks\":[],\"data\":{}}]},{\"nodeType\":\"paragraph\",\"data\":{},\"content\":[{\"nodeType\":\"text\",\"value\":\"Genre : Family, Adventure, Comedy, Musical, Action, Drama\",\"marks\":[],\"data\":{}}]},{\"nodeType\":\"paragraph\",\"data\":{},\"content\":[{\"nodeType\":\"text\",\"value\":\"Progress : Pre Production Finished, Early Production\\n\",\"marks\":[],\"data\":{}}]},{\"nodeType\":\"paragraph\",\"data\":{},\"content\":[{\"nodeType\":\"text\",\"value\":\"\",\"marks\":[],\"data\":{}}]},{\"nodeType\":\"paragraph\",\"data\":{},\"content\":[{\"nodeType\":\"text\",\"value\":\"\\nSuffered by illness in his short life, 5-year-old Jack, is about to enter the magical world and move into his only dream. While he is waiting to pass the heart surgery in the hospital that his survival depends on, his father leaves a broken lamp beside him. Change arrives in the shape of a mysterious Genie. Can the dreams come true? Is Jack about to jump on the adventure of a lifetime?\",\"marks\":[],\"data\":{}}]},{\"nodeType\":\"embedded-asset-block\",\"data\":{\"target\":{\"sys\":{\"id\":\"1jGq69AxMUoHvaftN45c9M\",\"type\":\"Link\",\"linkType\":\"Asset\"}}},\"content\":[]},{\"